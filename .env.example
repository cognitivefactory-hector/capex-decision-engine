# Copy to .env (gitignored) and fill in. NEVER commit .env or a real ANTHROPIC_API_KEY.

# --- Django ---
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-insecure-key-change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Comma-separated, scheme-qualified; needed in prod behind Cloudflare, e.g.:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://capex.hector-garza.com

# --- Anthropic (memo layer, M6; the LLM explains, it never decides) ---
ANTHROPIC_API_KEY=
MEMO_MODEL=claude-sonnet-4-6
